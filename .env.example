# API gateway (server) configuration
GATEWAY_PORT=8080
REST_BASE_URL=http://localhost:8080
SOAP_URL=http://localhost:3001/ws
CORS_ALLOWED_ORIGINS=*

# Values injected into the browser by /env.js (override for production)
# Set these to the API gateway origin when the frontend is deployed separately.
PUBLIC_GATEWAY_URL=https://api-gateway-gwzlj.ondigitalocean.app
PUBLIC_REST_URL=https://api-gateway-gwzlj.ondigitalocean.app/api
PUBLIC_SOAP_URL=https://api-gateway-gwzlj.ondigitalocean.app/gateway/soap
SOAP_NS=http://userauth.soap.service/
GATEWAY_URL=/gateway
