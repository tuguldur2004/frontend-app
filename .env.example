# API gateway (server) configuration
GATEWAY_PORT=8080
REST_BASE_URL=http://localhost:8080
SOAP_URL=http://localhost:3001/ws
CORS_ALLOWED_ORIGINS=*

# Values injected into the browser by /env.js.
# Keep this on a same-origin path so the browser stays on the page origin.
# The frontend derives /api, /api/soap, and /api/files from it.
PUBLIC_GATEWAY_URL=/
SOAP_NS=http://userauth.soap.service/
