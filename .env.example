# API gateway (server) configuration
GATEWAY_PORT=8080
REST_BASE_URL=http://localhost:8080
SOAP_URL=http://localhost:3001/ws
CORS_ALLOWED_ORIGINS=*

# Values injected into the browser by /env.js.
# Keep these on same-origin paths to avoid mixed-content errors in HTTPS browsers.
PUBLIC_GATEWAY_URL=/
PUBLIC_REST_URL=/api
PUBLIC_SOAP_URL=/api/soap
PUBLIC_FILE_MANAGER_URL=/api/files
SOAP_NS=http://userauth.soap.service/
