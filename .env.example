# API gateway (server) configuration
GATEWAY_PORT=8080
REST_BASE_URL=http://localhost:8080
SOAP_URL=http://localhost:3001/ws
CORS_ALLOWED_ORIGINS=*

# Values injected into the browser by /env.js (override for production)
# Set these to the current API gateway origin when the frontend is deployed separately.
PUBLIC_GATEWAY_URL=
PUBLIC_REST_URL=
PUBLIC_SOAP_URL=
SOAP_NS=http://userauth.soap.service/
